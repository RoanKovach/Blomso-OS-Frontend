# API base URL (e.g. https://your-api.execute-api.region.amazonaws.com/prod)
# Leave empty until your AWS backend is deployed.
VITE_API_URL=

# Cognito Hosted UI (optional). Callback stores the OAuth access_token for API Authorization (Bearer).
# VITE_APP_URL – Base URL of this app (e.g. https://main.xxx.amplifyapp.com or http://localhost:5173).
# VITE_COGNITO_DOMAIN – Cognito Hosted UI domain, no trailing slash (e.g. https://blomso-auth.auth.us-east-2.amazoncognito.com).
# VITE_COGNITO_CLIENT_ID – User Pool Client ID from backend (BlomsoUserPoolClientId).
# VITE_COGNITO_USER_POOL_ID – Optional; when set with client id, enables Amplify fetchAuthSession() for tokens.
# The callback URL (VITE_APP_URL + /auth/callback) must be allowed in the Cognito User Pool Client.
VITE_APP_URL=
VITE_COGNITO_DOMAIN=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_USER_POOL_ID=

# Mapbox access token for map tiles (get one at https://account.mapbox.com/)
# Required for Field Visualization map.
VITE_MAPBOX_TOKEN=
